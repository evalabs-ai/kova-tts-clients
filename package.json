{
  "name": "@kova-ai/tts",
  "version": "0.1.1",
  "description": "Official JavaScript/TypeScript client for the Kova TTS API.",
  "type": "module",
  "main": "./packages/js/dist/index.js",
  "types": "./packages/js/dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evalabs-ai/kova-tts-clients.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./packages/js/dist/index.d.ts",
      "import": "./packages/js/dist/index.js"
    }
  },
  "files": [
    "packages/js/dist",
    "packages/js/README.md",
    "README.md",
    "protocol"
  ],
  "scripts": {
    "build": "tsc -p packages/js/tsconfig.json",
    "example:js:stream": "npm run build && tsx examples/js/stream.ts",
    "example:js:sync": "npm run build && tsx examples/js/sync.ts",
    "example:js:websocket": "npm run build && tsx examples/js/websocket.ts",
    "example:py:stream": "PYTHONPATH=packages/python/src python3 examples/python/stream.py",
    "example:py:sync": "PYTHONPATH=packages/python/src python3 examples/python/sync.py",
    "example:py:websocket": "PYTHONPATH=packages/python/src python3 examples/python/websocket.py",
    "prepare": "npm run build",
    "test": "npm run build && node --test packages/js/test/*.test.mjs"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.12",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
